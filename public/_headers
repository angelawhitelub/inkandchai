# ── Cache rules — read top to bottom; first match wins per path ────────────

# 1. Never cache any HTML (browser must revalidate every time → instant updates)
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# 2. Pretty URLs (no .html) — same rule, browser always checks for updates
/
  Cache-Control: public, max-age=0, must-revalidate
/product/*
  Cache-Control: public, max-age=0, must-revalidate
/checkout/*
  Cache-Control: public, max-age=0, must-revalidate
/collection/*
  Cache-Control: public, max-age=0, must-revalidate
/category/*
  Cache-Control: public, max-age=0, must-revalidate
/admin/*
  Cache-Control: public, max-age=0, must-revalidate
/terms/*
  Cache-Control: public, max-age=0, must-revalidate
/privacy-policy/*
  Cache-Control: public, max-age=0, must-revalidate
/refund-policy/*
  Cache-Control: public, max-age=0, must-revalidate
/return-policy/*
  Cache-Control: public, max-age=0, must-revalidate
/shipping-policy/*
  Cache-Control: public, max-age=0, must-revalidate

# 3. JS — short cache + must-revalidate (so JS bug fixes ship same-day)
/*.js
  Cache-Control: public, max-age=300, must-revalidate
/js/*
  Cache-Control: public, max-age=300, must-revalidate

# 4. CSS — same
/*.css
  Cache-Control: public, max-age=300, must-revalidate

# 5. Images & fonts — cache hard for 1 year (filenames don't change)
/images/*
  Cache-Control: public, max-age=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.jpeg
  Cache-Control: public, max-age=31536000, immutable
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.svg
  Cache-Control: public, max-age=31536000, immutable
/*.woff
  Cache-Control: public, max-age=31536000, immutable
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# 6. Feed.xml — short cache so Google sees product updates
/feed.xml
  Cache-Control: public, max-age=600
