# ── Razorpay ─────────────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# Webhook secret — set when creating webhook in Razorpay Dashboard
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Frontend (injected into HTML at build time) ───────────────────────────────
# This is the PUBLIC key — safe to expose in browser
RAZORPAY_KEY_ID_PUBLIC=rzp_live_xxxxxxxxxxxx
